{
    "name": "marchalbersma/impish-core",
    "description": "A data importing library",
    "type": "library",
    "keywords": [
        "impish",
        "core",
        "data",
        "import"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Marc Halbersma",
            "email": "contact@marchalbersma.com"
        }
    ],
    "support": {
        "issues": "https://github.com/marchalbersma/impish/issues",
        "source": "https://github.com/marchalbersma/impish"
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "pestphp/pest": "^2.8"
    },
    "autoload": {
        "psr-4": {
            "Impish\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Impish\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
